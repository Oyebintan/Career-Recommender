# Copy this file to ".env" and fill in real values. Never commit the real .env file.

# Used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-64-character-hex-string

# PostgreSQL connection string: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://postgres:password@localhost:5432/career_recommender
FLASK_APP=app.py
FLASK_DEBUG=True

# Google OAuth (optional - get these from console.cloud.google.com)
# Leave blank to disable the Google sign-in button
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here