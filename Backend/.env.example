# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SECRET_KEY=d1f889517df68a253334fb3d14d793401f92e53d0173e3b5b5efeabd7d09f4f6


# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database_name
DATABASE_URL=DATABASE_URL=postgresql://postgres:password@localhost:5432/career_recommender


FLASK_APP=app.py
FLASK_DEBUG=True

# Google OAuth — get from console.cloud.google.com
# Leave blank to disable the Google sign-in button
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: override dataset path if your deployment layout differs
# DATASETS_DIR=/absolute/path/to/datasets/custom